{
  "openapi": "3.1.0",
  "info": {
    "title": "Paginea API",
    "description": "REST API for retrieving content from Paginea",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:9090",
      "description": "Generated server url"
    }
  ],
  "paths": {
    "/api/site/{site}/content/types/{type}/items": {
      "get": {
        "tags": [
          "Content Items"
        ],
        "summary": "Get content items of the given type, with optional filtering, sorting and pagination",
        "description": "Filter values use exact match against the field's text representation. Comparison follows the database collation (the default MySQL collation is case-insensitive). DATE fields additionally accept the operator prefixes `<`, `<=`, `>`, `>=`, `=` combined with the keyword `today` (e.g. `publishDate:<=today`, `publishDate:>today`); bare `today` and explicit `yyyy-MM-dd` values are also supported. Composite field types (REPEATABLE_GROUP, MIXED_CONTENT) and unknown field keys yield a 400 response.",
        "operationId": "getContentItems",
        "parameters": [
          {
            "name": "site",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Repeated filter entries in the form `key:value`. Multiple filters are AND'ed. Inner colons in values must be URL-encoded as %3A. For DATE fields, `value` may be `yyyy-MM-dd`, `today`, or an operator prefix (`<`, `<=`, `>`, `>=`, `=`) followed by `today` — e.g. `publishDate:<=today`.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort expression in the form `key` or `key,asc` / `key,desc`. Defaults to lastModifiedAt DESC when omitted. Pass the reserved keyword `random` (no direction) for random ordering; in that case `page` and `size` are not allowed and only `limit` applies.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Zero-based page index. Ignored when `limit` is supplied.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Page size. Ignored when `limit` is supplied.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Top-N cap. When supplied, returns the first N items and `page`/`size` are ignored.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ContentItem"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/site/{site}/content/types/{type}/items/count": {
      "get": {
        "tags": [
          "Content Items"
        ],
        "summary": "Count content items of the given type matching the supplied filters",
        "operationId": "getContentItemCount",
        "parameters": [
          {
            "name": "site",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Repeated filter entries in the form `key:value`. Multiple filters are AND'ed. Inner colons in values must be URL-encoded as %3A. For DATE fields, `value` may be `yyyy-MM-dd`, `today`, or an operator prefix (`<`, `<=`, `>`, `>=`, `=`) followed by `today` — e.g. `publishDate:<=today`.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ContentItemCount"
                }
              }
            }
          }
        }
      }
    },
    "/api/site/{site}/content/items/{item}": {
      "get": {
        "tags": [
          "Content Items"
        ],
        "summary": "Get a content item by its id",
        "operationId": "getContentItem",
        "parameters": [
          {
            "name": "site",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "item",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ContentItem"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BooleanField": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Field"
          },
          {
            "type": "object",
            "properties": {
              "booleanValue": {
                "type": "boolean",
                "description": "Boolean value"
              }
            }
          }
        ],
        "required": [
          "textValue"
        ],
        "x-discriminator-value": "boolean"
      },
