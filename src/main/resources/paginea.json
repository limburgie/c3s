{
  "openapi": "3.1.0",
  "info": {
    "title": "Paginea API",
    "description": "REST API for retrieving content from Paginea",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:9090",
      "description": "Generated server url"
    }
  ],
  "paths": {
    "/api/site/{site}/content/types/{type}/items": {
      "get": {
        "tags": [
          "Content Items"
        ],
        "summary": "Get all content items of the given type within the given site",
        "operationId": "getContentItems",
        "parameters": [
          {
            "name": "site",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ContentItem"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/site/{site}/content/items/{item}": {
      "get": {
        "tags": [
          "Content Items"
        ],
        "summary": "Get a content item by its id",
        "operationId": "getContentItem",
        "parameters": [
          {
            "name": "site",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "item",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ContentItem"
                }
              }
            }
          }
        }
      }
    }
  },
