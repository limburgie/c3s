            },
            "description": "The content item's values"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastModifiedAt": {
            "type": "string",
            "format": "date-time"
          },
          "editUrl": {
            "type": "string"
          }
        },
        "required": [
          "createdAt",
          "editUrl",
          "fields",
          "id",
          "lastModifiedAt"
        ]
      },
      "DateField": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Field"
          },
          {
            "type": "object",
            "properties": {
              "dateValue": {
                "type": "string",
                "format": "date",
                "description": "Date value"
              }
            }
          }
        ],
        "required": [
          "textValue"
        ],
        "x-discriminator-value": "date"
      },
      "Field": {
        "type": "object",
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "text": "#/components/schemas/TextField",
            "rich-text": "#/components/schemas/RichTextField",
            "number": "#/components/schemas/NumberField",
            "image": "#/components/schemas/ImageField",
            "media-link": "#/components/schemas/MediaLinkField",
            "date": "#/components/schemas/DateField",
            "boolean": "#/components/schemas/BooleanField",
            "group": "#/components/schemas/GroupField",
            "mixed-content": "#/components/schemas/MixedContentField"
