          },
          {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "description": "Items contained in this mixed content field",
                "items": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/BooleanField"
                    },
                    {
                      "$ref": "#/components/schemas/DateField"
                    },
                    {
                      "$ref": "#/components/schemas/GroupField"
                    },
                    {
                      "$ref": "#/components/schemas/ImageField"
                    },
