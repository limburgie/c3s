              "dateValue": {
                "type": "string",
                "format": "date",
                "description": "Date value"
              }
            }
          }
        ],
        "x-discriminator-value": "date"
      },
      "Field": {
        "type": "object",
        "discriminator": {
          "propertyName": "type",
          "mapping": {
